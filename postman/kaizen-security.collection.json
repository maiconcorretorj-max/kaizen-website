{
  "info": {
    "_postman_id": "8e180d7f-0f80-4cc4-aa6a-44ccf6799d8d",
    "name": "Kaizen - Security Baseline",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Baseline security checks for Kaizen website (Next.js + Supabase)."
  },
  "item": [
    {
      "name": "01 - Public Home Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 2xx', function () {",
              "  pm.expect(pm.response.code).to.be.within(200, 299);",
              "});",
              "",
              "pm.test('No stack trace leak', function () {",
              "  const body = pm.response.text();",
              "  pm.expect(body).to.not.match(/ReferenceError|TypeError|SyntaxError|stack trace|Unhandled/i);",
              "});",
              "",
              "pm.test('Security headers baseline', function () {",
              "  const names = pm.response.headers.all().map(h => h.key.toLowerCase());",
              "  const strong = ['content-security-policy', 'x-frame-options', 'x-content-type-options', 'referrer-policy'];",
              "  const present = strong.filter(h => names.includes(h)).length;",
              "  pm.expect(present).to.be.at.least(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Admin Protected (Unauthenticated)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin unauthenticated is blocked', function () {",
              "  pm.expect([200, 301, 302, 307, 308, 401, 403]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Never returns 500', function () {",
              "  pm.expect(pm.response.code).to.not.equal(500);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Login User (Supabase Auth)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "apikey",
            "value": "{{supabaseAnonKey}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
          "host": [
            "{{supabaseUrl}}"
          ],
          "path": [
            "auth",
            "v1",
            "token"
          ],
          "query": [
            {
              "key": "grant_type",
              "value": "password"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (!pm.environment.get('userEmail') || !pm.environment.get('userPassword')) {",
              "  const email = pm.variables.get('userEmail') || pm.collectionVariables.get('userEmail');",
              "  const password = pm.variables.get('userPassword') || pm.collectionVariables.get('userPassword');",
              "  if (!email || !password) {",
              "    pm.test('User credentials are optional for baseline', function () {",
              "      pm.expect(true).to.equal(true);",
              "    });",
              "  }",
              "}",
              "",
              "pm.test('User login status', function () {",
              "  pm.expect([200, 400, 401]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  pm.environment.set('userAccessToken', json.access_token);",
              "  pm.collectionVariables.set('userAccessToken', json.access_token);",
              "  pm.test('User token captured', function () {",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "  });",
              "  }",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Try Write CMS as User (Should Fail)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "apikey",
            "value": "{{supabaseAnonKey}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{userAccessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[{\n  \"page_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"section_key\": \"security_test\",\n  \"section_type\": \"custom\",\n  \"content\": {\"test\": true}\n}]"
        },
        "url": {
          "raw": "{{supabaseUrl}}/rest/v1/page_sections",
          "host": [
            "{{supabaseUrl}}"
          ],
          "path": [
            "rest",
            "v1",
            "page_sections"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CMS write blocked for non-admin', function () {",
              "  pm.expect(pm.response.code).to.not.be.within(200, 299);",
              "  pm.expect([401, 403, 404, 409]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Public Sections Should Not Leak Draft",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "apikey",
            "value": "{{supabaseAnonKey}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{supabaseAnonKey}}"
          }
        ],
        "url": {
          "raw": "{{supabaseUrl}}/rest/v1/page_sections?select=id,section_key,section_type,status,is_active",
          "host": [
            "{{supabaseUrl}}"
          ],
          "path": [
            "rest",
            "v1",
            "page_sections"
          ],
          "query": [
            {
              "key": "select",
              "value": "id,section_key,section_type,status,is_active"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Read returns success', function () {",
              "  pm.expect([200, 206]).to.include(pm.response.code);",
              "});",
              "",
              "const rows = pm.response.json();",
              "pm.test('No draft rows for public', function () {",
              "  const hasDraft = Array.isArray(rows) && rows.some(r => (r.status || '').toLowerCase() !== 'published');",
              "  pm.expect(hasDraft).to.equal(false);",
              "});",
              "",
              "pm.test('Only active rows for public', function () {",
              "  const hasInactive = Array.isArray(rows) && rows.some(r => r.is_active === false);",
              "  pm.expect(hasInactive).to.equal(false);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06 - XSS Probe on Public Route",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/contato?q=%3Cscript%3Ealert(1)%3C%2Fscript%3E",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "contato"
          ],
          "query": [
            {
              "key": "q",
              "value": "<script>alert(1)</script>"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('No reflected raw script payload', function () {",
              "  const body = pm.response.text();",
              "  pm.expect(body).to.not.include('<script>alert(1)</script>');",
              "});",
              "",
              "pm.test('No 5xx on malicious query', function () {",
              "  pm.expect(pm.response.code).to.be.below(500);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://imobkaizen.com.br"
    },
    {
      "key": "supabaseUrl",
      "value": "https://YOUR_PROJECT.supabase.co"
    },
    {
      "key": "supabaseAnonKey",
      "value": "YOUR_SUPABASE_ANON_KEY"
    },
    {
      "key": "userEmail",
      "value": ""
    },
    {
      "key": "userPassword",
      "value": ""
    },
    {
      "key": "userAccessToken",
      "value": ""
    }
  ]
}
